---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — Kuruwa Cycles" description="This page doesn't exist.">
  <section class="min-h-screen bg-surface-dark flex flex-col items-center justify-center px-6 py-20 text-center gap-6">
    <p class="font-mono text-xs text-fg-secondary tracking-[3px]">404</p>
    <h1 class="font-display text-[48px] md:text-[120px] leading-[0.9] text-white tracking-tight">WRONG TURN</h1>
    <p class="font-body text-base md:text-lg text-fg-secondary leading-relaxed max-w-md">
      This page doesn't exist. Let's get you back on track.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-3 bg-accent text-white font-mono text-[13px] font-medium tracking-[2px] px-8 py-4 hover:bg-red-700 transition-colors"
    >
      BACK TO HOME
    </a>
  </section>
</Layout>
